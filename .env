# React Environment Variables
# Prefix all variables with REACT_APP_ to expose them to the frontend

# ─── App Info ─────────────────────────────────────────────────
REACT_APP_SITE_TITLE=Philip John Cidro — Full-Stack Developer
REACT_APP_SITE_URL=http://localhost:3000

# ─── Contact / API ────────────────────────────────────────────
# If you add a backend API later (e.g. Express + SQLite), set this:
REACT_APP_API_URL=http://localhost:5001/api
REACT_APP_CONTACT_ENDPOINT=/contact

# ─── Feature Flags ────────────────────────────────────────────
REACT_APP_ENABLE_ANALYTICS=false
REACT_APP_DISABLE_SECURITY_HARDENING=false

# ─── Note ─────────────────────────────────────────────────────
# SQLite is a server-side database. To use it with this React app,
# add an Express/Node.js backend and point REACT_APP_API_URL above
# to your server. The contact form is ready to hit that endpoint.
# Example backend stack: Express + better-sqlite3
